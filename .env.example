# ───── 데이터베이스 (필수) ─────
# PostgreSQL 연결 URL — Neon, Supabase, Vercel Postgres 등 사용 가능
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ───── Vercel Blob Storage (선택) ─────
# 테스트 아티팩트(스크린샷, 비디오, 로그) 업로드용
# https://vercel.com/dashboard 에서 발급
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxx"

# ───── 데모 모드 (선택) ─────
# "true"로 설정 시 모든 민감 데이터를 마스킹 처리
NEXT_PUBLIC_DEMO_MODE="false"

# 데모 모드 활성화 시, 추가로 치환할 키워드 목록 (쉼표 구분)
# 예: 회사명, 서비스명을 일반화하고 싶을 때
# NEXT_PUBLIC_DEMO_KEYWORDS="MyCompany,InternalService"

# ───── AI 분석 (선택) ─────
# 실패 테스트 케이스 자동 분석 기능
# Vercel AI Gateway 또는 Anthropic API 키 중 하나 설정
AI_GATEWAY_API_KEY=""
ANTHROPIC_API_KEY=""
